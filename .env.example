# ── Database ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sse_dev
POSTGRES_USER=sse_user
POSTGRES_PASSWORD=sse_password_dev

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=sse_redis_dev

# ── Auth (Auth0 / Clerk) ──
AUTH_PROVIDER=clerk
AUTH_DOMAIN=
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=
AUTH_AUDIENCE=

# ── JWT ──
JWT_SECRET=your-jwt-secret-change-me
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ── Encryption ──
ENCRYPTION_MASTER_KEY=your-256-bit-master-key-in-base64
AWS_KMS_KEY_ID=

# ── AWS S3 / Storage ──
STORAGE_PROVIDER=s3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=sse-uploads-dev

# ── API ──
API_PORT=3001
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── n8n ──
N8N_USER=admin
N8N_PASSWORD=admin
N8N_WEBHOOK_URL=http://localhost:5678

# ── OpenAI (Phase 2) ──
OPENAI_API_KEY=

# ── Plaid (Phase 2) ──
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# ── Stripe Billing ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Logging ──
LOG_LEVEL=debug
LOG_FORMAT=json

# ── Environment ──
NODE_ENV=development
