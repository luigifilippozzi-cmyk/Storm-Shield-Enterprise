# ── Database ──
# For managed databases (Neon, AWS RDS), set DATABASE_URL and DATABASE_URL_UNPOOLED.
# DATABASE_URL is the pooled connection string (used at runtime).
# DATABASE_URL_UNPOOLED is the direct connection string (used for migrations/DDL).
# When these are set, the discrete POSTGRES_* vars below are ignored.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require
# DATABASE_URL_UNPOOLED=postgresql://user:pass@host:5432/dbname?sslmode=require

# Local dev — used when DATABASE_URL is not set
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sse_dev
# Admin user (migrations, provisioning — bypasses RLS)
POSTGRES_USER=sse_user
POSTGRES_PASSWORD=sse_password_dev
# App user (runtime queries — subject to RLS policies)
POSTGRES_APP_USER=sse_app
POSTGRES_APP_PASSWORD=sse_app_password_dev

# ── Redis ──
# For managed Redis (Upstash), set REDIS_URL.
# When set, the discrete REDIS_* vars below are ignored.
# REDIS_URL=rediss://default:TOKEN@host:6379

# Local dev — used when REDIS_URL is not set
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=sse_redis_dev

# ── Clerk Auth ──
# Get these from https://dashboard.clerk.com → your app → API Keys
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# Optional: PEM public key for local JWT verification (faster, no network call)
CLERK_JWT_KEY=
# Clerk sign-in/up routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register

# ── Encryption ──
ENCRYPTION_MASTER_KEY=your-256-bit-master-key-in-base64
AWS_KMS_KEY_ID=

# ── AWS S3 / Storage ──
STORAGE_PROVIDER=s3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=sse-uploads-dev

# ── API ──
API_PORT=3001
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── n8n ──
N8N_USER=admin
N8N_PASSWORD=admin
N8N_WEBHOOK_URL=http://localhost:5678

# ── OpenAI (Phase 2) ──
OPENAI_API_KEY=

# ── Plaid (Phase 2) ──
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# ── Stripe Billing ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Logging ──
LOG_LEVEL=debug
LOG_FORMAT=json

# ── Environment ──
NODE_ENV=development
