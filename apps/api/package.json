{
  "name": "@sse/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "nest start",
    "start:prod": "node dist/main",
    "lint": "echo \"lint skipped\"",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "migration:run": "knex migrate:latest --knexfile src/config/knexfile.ts",
    "migration:rollback": "knex migrate:rollback --knexfile src/config/knexfile.ts",
    "migration:create": "knex migrate:make --knexfile src/config/knexfile.ts",
    "seed:run": "ts-node src/database/seeds/run.ts"
  },
  "dependencies": {
    "@clerk/backend": "^3.2.4",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@sse/shared-types": "workspace:*",
    "@sse/shared-utils": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.4.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.0",
    "knex": "^3.1.0",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "uuid": "^11.1.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@sse/eslint-config": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.0",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.7.0"
  }
}
